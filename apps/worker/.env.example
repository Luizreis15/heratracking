# Worker — copie para .env e preencha os valores reais
# NUNCA commite este arquivo com valores reais

# Motores híbridos (ambos obrigatórios)
# Perplexity → pesquisa BOM, concorrência, intel web
# Claude     → BOM fases 2–6, comparativo estratégico
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar-pro
ANTHROPIC_API_KEY=sk-ant-...

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=...

# Intervalo de poll para novos jobs (ms)
POLL_INTERVAL_MS=5000

# Scan automático de inteligência (horas). 0 = só manual. Ex.: 24 = 1x/dia por operação
INTEL_AUTO_SCAN_HOURS=0

# Meta Graph — bridge com frontend-premium-zero (projeto anetxebdklhfbltebial)
# Service role do painel Hera — NUNCA no frontend Tracking
# HERA_PREMIUM_SUPABASE_URL=https://anetxebdklhfbltebial.supabase.co
# HERA_PREMIUM_SERVICE_ROLE_KEY=
# HERA_PREMIUM_CLIENT_ID=          # fallback UUID do cliente Hera DG
# META_GRAPH_VERSION=v21.0
